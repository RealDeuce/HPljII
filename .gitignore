# Local ROM dump artifacts. Keep raw reads, verified images, and interleaves
# out of the repository; track manifests/scripts/notes instead.
*.bin
*.BIN

# Generated local analysis output derived from ROM contents. Keep bulk/raw
# outputs local, but track the text evidence files cited by checked-in notes.
generated/*
!generated/analysis/
generated/analysis/*
!generated/analysis/*.md
!generated/disasm/
generated/disasm/*
!generated/disasm/*.lst

# Local Python bytecode caches from analysis scripts.
__pycache__/
*.py[cod]
